      "source": [
        "import math\n",
        "while True:\n",
        "    while True:\n",
        "        try:\n",
        "            num1 = int(input(\"첫 번째 정수: \"))\n",
        "            break\n",
        "        except ValueError:\n",
        "            print(\"잘못된 입력입니다 정수만 입력해주세요.\")\n",
        "    while True:\n",
        "        try:\n",
        "            num2 = int(input(\"두번째 정수: \"))\n",
        "            break\n",
        "        except ValueError:\n",
        "            print(\"잘못된 정수.\")\n",
        "    calc = input(\"연산자(+, -, *, /, **): \")\n",
        "    try:\n",
        "        if calc == \"+\":\n",
        "            result = num1 + num2\n",
        "        elif calc == \"-\":\n",
        "            result = num1 - num2\n",
        "        elif calc == \"*\":\n",
        "            result = num1 * num2\n",
        "        elif calc == \"/\":\n",
        "            result = num1 / num2\n",
        "        elif calc == \"**\":\n",
        "            result = math.pow(num1, num2)\n",
        "        else:\n",
        "            raise ValueError(\"지원하지 않는 연산자.\")\n",
        "        print(f\"결과: {result}\")\n",
        "    except ZeroDivisionError:\n",
        "        print(\"0으로 나눌 수 없음.\")\n",
        "    except ValueError as e:\n",
        "        print(e)\n",
        "    again = input(\"계속 계산할거야? (네/아니요): \").lower()\n",
        "    if again != '네':\n",
        "        print(\"종료.\")\n",
        "        break"
